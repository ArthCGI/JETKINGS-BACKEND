{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=JetKingsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "REPLACE_WITH_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "JetKingsAPI",
    "Audience": "JetKingsClient",
    "ExpiryMinutes": 60
  }
}
